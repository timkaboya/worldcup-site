---
interface Props {
  active: 'schedule' | 'tables' | 'scorers' | 'assists' | 'bracket' | 'news';
}
const { active } = Astro.props;

const base = import.meta.env.BASE_URL; // '/', or e.g. '/worldcup-site/'
const link = (href: string) => (href === '/' ? base : base.replace(/\/$/, '') + href);

const tabs = [
  { id: 'schedule', href: '/', emoji: '📅', label: 'Schedule' },
  { id: 'tables', href: '/tables', emoji: '📊', label: 'Tables' },
  { id: 'scorers', href: '/scorers', emoji: '👟', label: 'Top Scorers' },
  { id: 'assists', href: '/assists', emoji: '🅰️', label: 'Assists' },
  { id: 'bracket', href: '/bracket', emoji: '🏆', label: 'Bracket' },
  { id: 'news', href: '/news', emoji: '📰', label: 'News' },
] as const;
---

<nav class="tabs" aria-label="Primary">
  {
    tabs.map((t) => (
      <a
        class:list={['tab', { active: active === t.id }]}
        href={link(t.href)}
        aria-label={t.label}
        aria-current={active === t.id ? 'page' : undefined}
      >
        <span class="ef">{t.emoji}</span>
        <span class="tab-lbl">{t.label}</span>
      </a>
    ))
  }
</nav>
