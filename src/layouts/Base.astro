---
import '../styles/tokens.css';
import '../styles/app.css';
import TabNav from '../components/TabNav.astro';

interface Props {
  title?: string;
  active: 'schedule' | 'tables' | 'scorers' | 'bracket' | 'news';
}

const { title = 'World Cup 2026', active } = Astro.props;
const base = import.meta.env.BASE_URL; // '/', or e.g. '/worldcup-site/'
const asset = (p: string) => base.replace(/\/$/, '') + p;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0d1b3e" />
    <meta
      name="description"
      content="Follow the FIFA World Cup 2026 — live scores, stats, tables, top scorers, bracket, and news, in your timezone. No sign-up."
    />
    <title>{title}</title>
    <link rel="manifest" href={asset('/manifest.webmanifest')} />
    <link rel="icon" href={asset('/icons/favicon.svg')} type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700;800&family=Noto+Color+Emoji&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <header class="hdr">
      <div class="brand">
        <span class="ef ef-lg">⚽</span>
        <div>
          <div class="brand-name">World Cup 2026</div>
          <div class="brand-sub">Your timezone · Live</div>
        </div>
      </div>
      <div class="hdr-right">
        <span id="live-pill" class="live-pill" title="This site is live and auto-refreshing">
          <span class="pulse"></span><span id="live-label">Live</span>
        </span>
        <span id="tz-badge" class="tz-badge">🕐 <span id="tz-label"></span></span>
      </div>
    </header>

    <TabNav active={active} />

    <main id="main">
      <slot />
    </main>

    <script is:inline define:vars={{ swPath: asset('/sw.js') }}>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register(swPath).catch(() => {});
        });
      }
    </script>

    <!-- Show the viewer's real timezone in the header on every page (the
         interactive Schedule island only runs on one route). -->
    <script is:inline>
      (function () {
        try {
          var tz;
          var raw = localStorage.getItem('wc2026:prefs');
          if (raw) tz = (JSON.parse(raw) || {}).timezone;
          tz = tz || Intl.DateTimeFormat().resolvedOptions().timeZone || 'UTC';
          var seg = (tz.split('/').pop() || tz).replace(/_/g, ' ');
          var el = document.getElementById('tz-label');
          if (el) el.textContent = seg;
        } catch (e) {
          /* no-op */
        }
      })();
    </script>
  </body>
</html>
