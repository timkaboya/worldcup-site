---
import Base from '../layouts/Base.astro';
import tournament from '../data/tournament.json';
import type { Scorer } from '../lib/types';
import Leaders from '../components/Leaders.tsx';

const SCORERS = (tournament.scorers ?? []) as Scorer[];
---

<Base title="Top Scorers · World Cup 2026" active="scorers">
  <div class="container">
    <div class="page-head">
      <h1 class="page-title">Golden Boot Race</h1>
      <p class="page-sub">Goals scored so far — ties broken by assists.</p>
    </div>
    <Leaders client:load kind="scorers" initial={SCORERS} />
  </div>
</Base>
