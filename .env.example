# Paystack "Support / Buy me a coffee" — copy to `.env` and fill in.
# Only the PUBLIC key is exposed to the browser (safe). Without it, the Support
# button simply does not render.
#
#   cp .env.example .env
#
# Get your keys from the Paystack dashboard → Settings → API Keys & Webhooks.

# Public key (pk_test_… while testing, pk_live_… in production).
PUBLIC_PAYSTACK_KEY=

# ISO currency for donations, matching your Paystack account (NGN, KES, GHS, ZAR, USD).
PUBLIC_PAYSTACK_CURRENCY=NGN

# ── Server-side only (DO NOT put the secret key here for a committed build) ──
# The secret key powers /api/verify-payment and must be set as a Cloudflare
# environment secret, NEVER committed:
#   npx wrangler pages secret put PAYSTACK_SECRET_KEY
# For local `wrangler pages dev`, put it in an untracked `.dev.vars` file:
#   PAYSTACK_SECRET_KEY=sk_test_xxx
